# LND node (required)
LND_REST_URL=https://localhost:8081
LND_TLS_CERT_PATH=/home/user/.polar/networks/1/volumes/lnd/alice/tls.cert
LND_MACAROON_PATH=/home/user/.polar/networks/1/volumes/lnd/alice/data/chain/bitcoin/regtest/admin.macaroon

# SQLite path (scheduler and API use this; default rebalancer.db)
# REBALANCER_DB_PATH=rebalancer.db

# Target ratio band: healthy = ratio in [TARGET_RATIO_LOW, TARGET_RATIO_HIGH]
# TARGET_RATIO_LOW=0.40
# TARGET_RATIO_HIGH=0.60

# Alerts: webhook (Discord or Telegram bridge) and optional SendGrid email
# ALERT_LEVEL=critical   # or warning, off
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERT_EMAIL_API_KEY=
# ALERT_EMAIL_FROM=
# ALERT_EMAIL_TO=

# Optional: heuristic for dashboard/simulator "cost of not rebalancing" (sats per forward)
# ESTIMATED_EXTRA_COST_PER_FORWARD_SATS=50

# InfluxDB + Grafana (optional; omit to run without metrics)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=mytoken123
INFLUXDB_ORG=lightning
INFLUXDB_BUCKET=channels
